      "parameters": {
        "jsCode": "// Process every new row delivered by the trigger — each item is a genuinely new submission.\n// If multiple rows arrive in the same poll window, all are evaluated for low-rating alerts.\nreturn $input.all().map(item => {\n  const body = item.json.body || item.json;\n\n  const satisfactionRaw =\n    body['Overall, how satisfied are you with our product/service?'] ||\n    body.satisfaction_rating ||\n    body.satisfactionRating ||\n    0;\n\n  const npsRaw =\n    body['How likely are you to recommend us to a friend or colleague?'] ||\n    body.nps_rating ||\n    body.npsRating ||\n    0;\n\n  return {\n    json: {\n      timestamp: body['Timestamp'] || body.timestamp || new Date().toISOString(),\n      satisfaction_rating: Number(satisfactionRaw),\n      nps_rating: Number(npsRaw),\n      comments: body['Comments'] || body.comments || '',\n      order_id: body['Order ID'] || body.order_id || body.orderId || '',\n      customer_email: body['Customer Email'] || body.customer_email || body.customerEmail || '',\n      customer_first_name: body['Customer First Name'] || body.customer_first_name || body.customerFirstName || ''\n    }\n  };\n});"
      },
      "id": "d2a7915f-6abc-40d6-9057-e8682182b7a2",
      "name": "Code - Parse Form Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
