    {
      "parameters": {
        "jsCode": "const allItems = $input.all();\n\n// Filter to today's entries in IST\nconst todayStr = new Date().toLocaleDateString('en-CA', { timeZone: 'Asia/Kolkata' }); // YYYY-MM-DD\nconst items = allItems.filter(i => {\n  const ts = i.json.created_at;\n  if (!ts) return false;\n  return new Date(ts).toLocaleDateString('en-CA', { timeZone: 'Asia/Kolkata' }) === todayStr;\n});\n\nconst total = items.length;\nconst outreach = items.filter(i => Number(i.json.outreach_attempts || 0) > 0).length;\nconst recovered = items.filter(i => i.json.workflow_status === 'recovered').length;\nconst pending = items.filter(i => i.json.workflow_status === 'pending').length;\nconst recoveryRate = outreach > 0 ? ((recovered / outreach) * 100).toFixed(1) : '0';\n\nreturn [{\n  json: {\n    summary: `:shopping_trolley: *Daily Cart Recovery Report*\\n\\n` +\n      `• Total checkouts today: *${total}*\\n` +\n      `• Recovery emails sent: *${outreach}*\\n` +\n      `• Carts recovered: *${recovered}*\\n` +\n      `• Pending (no outreach yet): *${pending}*\\n` +\n      `• Recovery rate: *${recoveryRate}%*\\n\\n` +\n      `_Report generated: ${new Date().toLocaleString('en-US', { timeZone: 'Asia/Kolkata' })} IST_`\n  }\n}];"
      },
      "id": "3afa425f-11fa-4ba9-80ef-6ca44646e344",
