    {
      "parameters": {
        "jsCode": "const allItems = $input.all();\n\n// Filter to last 7 days\nconst weekAgo = new Date();\nweekAgo.setDate(weekAgo.getDate() - 7);\nweekAgo.setHours(0, 0, 0, 0);\n\nconst items = allItems.filter(i => {\n  const ts = i.json['Timestamp'] || i.json.timestamp;\n  return ts && new Date(ts) >= weekAgo;\n});\n\nconst ratings = items\n  .map(i => Number(i.json['Overall, how satisfied are you with our product/service?'] || i.json.satisfaction_rating || 0))\n  .filter(r => r > 0);\n\nconst nps = items\n  .map(i => Number(i.json['How likely are you to recommend us to a friend or colleague?'] || i.json.nps_rating || 0))\n  .filter(r => r > 0);\n\nconst avgSat = ratings.length ? (ratings.reduce((a,b) => a+b, 0) / ratings.length).toFixed(2) : 'N/A';\nconst avgNps = nps.length ? (nps.reduce((a,b) => a+b, 0) / nps.length).toFixed(2) : 'N/A';\nconst lowRatingCount = ratings.filter(r => r < 3).length;\n\nreturn [{\n  json: {\n    avgSat,\n    avgNps,\n    count: items.length,\n    lowRatingCount,\n    summary:\n      `:bar_chart: *Weekly Customer Feedback Summary*\\n\\n` +\n      `• Total responses this week: *${items.length}*\\n` +\n      `• Avg satisfaction: *${avgSat}/5*\\n` +\n      `• Avg NPS score: *${avgNps}/10*\\n` +\n      `• Low ratings (< 3): *${lowRatingCount}*\\n\\n` +\n      `_Week ending: ${new Date().toLocaleDateString('en-GB')}_`\n  }\n}];"
      },
